# Go
*.test
*.out
coverage.txt
/dist/

# Python ref env (also matches symlinks used by side-branch worktrees)
testharness/.venv
testharness/__pycache__/
**/__pycache__/
*.pyc

# Fetched test assets (regenerable; also matches symlinks)
testdata/models
testdata/corpora

# Large golden fixtures generated from the 10k corpus; regenerate via `make diff-test`.
testdata/golden/*-tokenizer-10k.json

# Large per-op golden fixtures (regenerated via `make diff-test`).
testdata/golden/ops-*.json

# Editor cruft
.idea/
.vscode/
*.swp

# pinned upstream spaCy clone, used by code-walks and the exception generator
upstream/

# Stray binaries from running `go build` in example dirs
/load-spacy-bundle
/load-thinc-model
/tokenize
/bench
/comprehensive-analyzer
